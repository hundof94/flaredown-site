# ─── X / Twitter API ──────────────────────────────────────────────────────────
# Required to show X/Twitter posts in the live feed.
# Get a Bearer Token from https://developer.twitter.com/en/portal/dashboard
# (Free tier allows recent search: 1M tweets/month)
X_BEARER_TOKEN=

# ─── Optional: Python scraper service ─────────────────────────────────────────
# URL of the self-hosted FastAPI scraper (see /scraper directory).
# If unset, the Next.js API routes call Reddit/PubMed directly.
SCRAPER_URL=http://localhost:8000
